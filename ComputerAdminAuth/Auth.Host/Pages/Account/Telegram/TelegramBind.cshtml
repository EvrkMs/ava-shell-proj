@page
@using Auth.Host.Pages.Account.Telegram
@model TelegramBindModel
@{
    ViewData["Title"] = "Привязка Telegram";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen flex items-center justify-center p-6 bg-slate-50">
    <div class="w-full max-w-md bg-white shadow rounded-xl p-6 space-y-4">
        <h1 class="text-xl font-semibold">Привязка Telegram</h1>
        
        @if (!User.Identity?.IsAuthenticated ?? true)
        {
            <div class="text-red-700 bg-red-50 border border-red-200 p-3 rounded">
                Для привязки необходимо войти.
                <a href="/Account/Login" class="underline">Войти</a>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model?.Error))
            {
                <div class="text-red-700 bg-red-50 border border-red-200 p-3 rounded">
                    <i class="fas fa-exclamation-circle mr-2"></i>
                    @Model.Error
                </div>
            }
            
            @if (!string.IsNullOrEmpty(Model?.Message))
            {
                <div class="text-green-700 bg-green-50 border border-green-200 p-3 rounded">
                    <i class="fas fa-check-circle mr-2"></i>
                    @Model.Message
                </div>
                
                @if (!string.IsNullOrEmpty(Model?.ReturnUrl))
                {
                    <a href="@Model.ReturnUrl" class="inline-block mt-2 bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
                        Вернуться
                    </a>
                }
            }
            else
            {
                <p class="text-slate-600">Нажмите кнопку ниже, чтобы привязать ваш Telegram-аккаунт.</p>
                
                    var ru = Model?.ReturnUrl ?? "/";
                    var callbackUrl = Url.Page(
                        "/Account/Telegram/TelegramBind",
                        null,
                        new { handler = "Verify", returnUrl = ru },
                        Request.Scheme
                    );
                
                <script async src="https://telegram.org/js/telegram-widget.js?22"
                        data-telegram-login="ava_smena_bot"
                        data-size="large"
                        data-userpic="false"
                        data-request-access="write"
                        data-lang="ru"
                        data-auth-url="@callbackUrl">
                </script>
            }
            
            <div class="mt-4 pt-4 border-t">
                <a href="@(Model?.ReturnUrl ?? "/")" class="text-gray-600 hover:text-gray-800 text-sm">
                    ← Назад
                </a>
            </div>
        }
    </div>
</body>
</html>