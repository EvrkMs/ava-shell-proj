@page
@model Auth.Host.Pages.Account.Telegram.InitDataModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вход через Telegram WebApp</title>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
          const qs = new URLSearchParams(location.search);
          const returnUrl = qs.get('returnUrl') || '/';
          const toLogin = () => {
            window.location.href = `/Account/Login?returnUrl=${encodeURIComponent(returnUrl)}`;
          };

          const tg = window.Telegram && window.Telegram.WebApp;
          const initData = tg && tg.initData;
          if (!initData) { toLogin(); return; }

          try {
            const res = await fetch(location.pathname, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ initData, returnUrl })
            });

            // читаем JSON даже при 401
            const data = await res.json().catch(() => ({}));
            if (data && data.redirect) {
              window.location.href = data.redirect;
              return;
            }
            toLogin();
          } catch {
            toLogin();
          }
        });
    </script>
</head>
<body>
    Входим через Telegram…
</body>
</html>
